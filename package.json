{
  "name": "play-it-all-web",
  "version": "0.1.1",
  "private": true,
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron": "wait-on http://localhost:3000 && PLAYITALL_DEV_SERVER_URL=http://localhost:3000 electron .",
    "electron:dev": "concurrently -k \"npm run dev\" \"npm run electron\"",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.playitall.app",
    "productName": "Play It All",
    "asar": true,
    "files": [
      "app/**/*",
      "components/**/*",
      "electron/**/*",
      "lib/**/*",
      "stores/**/*",
      "public/**/*",
      ".next/**/*",
      "next.config.ts",
      "package.json",
      "node_modules/**/*"
    ],
    "mac": {
      "icon": "electron/assets/icon.icns",
      "category": "public.app-category.music",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "electron/assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "electron/assets/icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Audio"
    }
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.99.2",
    "blueimp-md5": "^2.19.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/blueimp-md5": "^2.18.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.5"
  }
}
